{
    "name": "nilesh/performance-optimisation",
    "description": "A WordPress plugin for performance optimization, including caching, HTML/CSS/JS minification, and image optimization.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Nilesh Kanzariya",
            "email": "nilesh.kanzariya912@gmail.com",
            "homepage": "https://profiles.wordpress.org/nileshkanzariya/",
            "role": "Developer"
        }
    ],
    "keywords": [
        "wordpress",
        "plugin",
        "performance",
        "optimization",
        "cache",
        "minify",
        "images",
        "webp",
        "avif"
    ],
    "support": {
        "issues": "https://github.com/example-repo/performance-optimisation/issues",
        "source": "https://github.com/example-repo/performance-optimisation"
    },
    "require": {
        "php": ">=7.4",
        "voku/html-min": "^4.5",
        "matthiasmullie/minify": "^1.3"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.6",
        "brain/monkey": "^2.6",
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "scripts": {
        "lint": "phpcs",
        "lint-fix": "phpcbf",
        "analyze": "phpstan analyse",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage/",
        "quality": [
            "@lint",
            "@analyze",
            "@test"
        ]
    },
    "autoload": {
        "psr-4": {
            "PerformanceOptimisation\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PerformanceOptimisation\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true
        },
        "platform": {
            "php": "7.4"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "wordpress-plugin-slug": "performance-optimisation",
        "primary-branch": "main"
    }
}