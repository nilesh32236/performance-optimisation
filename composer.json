{
    "name": "nilesh/performance-optimisation",
    "description": "A package for performance optimization, including HTML minification and code minification tools.",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "nilesh",
            "email": "nilesh.kanzariya912@gmail.com"
        }
    ],
    "require": {
        "voku/html-min": "^4.5",
        "matthiasmullie/minify": "^1.3",
        "woocommerce/action-scheduler": "^3.8"
    },
    "extra": {
        "cleanup": {
            "dirs": ["bin", "tests", "docs"],
            "exclude": ["*.md", "*.yml", "*.xml", "tests", "docs"]
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3",
        "phpcsstandards/phpcsextra": "^1.5",
        "phpcsstandards/phpcsutils": "^1.2"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "release": "composer install --no-dev --optimize-autoloader --ignore-platform-reqs",
        "dev-setup": "composer install --ignore-platform-reqs"
    }
}
