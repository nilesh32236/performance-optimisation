{
  "name": "performance-optimisation",
  "version": "2.0.0",
  "description": "A WordPress plugin for performance optimization, including caching, HTML/CSS/JS minification, and image optimization.",
  "main": "build/index.js",
  "private": true,
  "scripts": {
    "build": "webpack --config admin/webpack.config.js --mode=production",
    "build:dev": "webpack --config admin/webpack.config.js --mode=development",
    "start": "webpack --config admin/webpack.config.js --mode=development --watch",
    "lint:js": "eslint 'admin/src/**/*.{js,jsx,ts,tsx}'",
    "lint:css": "stylelint 'admin/src/**/*.scss'",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "author": {
    "name": "Nilesh Kanzariya",
    "email": "nilesh.kanzariya912@gmail.com",
    "url": "https://profiles.wordpress.org/nileshkanzariya/"
  },
  "license": "GPL-2.0-or-later",
